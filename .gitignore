# Terraform
# Stato di Terraform: contiene dati sensibili (anche il token). MAI committarlo.
*.tfstate
*.tfstate.*

# Cartella di lavoro con i provider scaricati
.terraform/
crash.log
crash.*.log

# I tuoi valori reali (endpoint, IP, ecc.)
terraform.tfvars
*.auto.tfvars

# File di override locali
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# NB: .terraform.lock.hcl NON e' qui apposta: il lock file VA committato,
# serve a bloccare le versioni esatte dei provider per tutti.


# Ansible
ansible/*.retry
ansible/.vault_pass
ansible/vault_password_file
*.vault
*.vault.yml

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
