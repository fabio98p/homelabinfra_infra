environment  = "homelab"
network_cidr = "192.168.1.0/24"

# ── Proxmox ──────────────────────────────────────────────────────────────────
proxmox_api_url      = "https://192.168.1.1:8006/api2/json"
proxmox_user         = "root@pam"
proxmox_password     = "changeme"
proxmox_tls_insecure = true
proxmox_node         = "pve"

# ── VM defaults ───────────────────────────────────────────────────────────────
vm_template       = "ubuntu-22.04-template"
vm_storage        = "local-lvm"
vm_default_cores  = 2
vm_default_memory = 2048
vm_ssh_public_key = "ssh-ed25519 AAAA... user@homelab"
